[Unit]
Description=Mogotor server analytics
After=network.target

[Service]
Type=simple
User=@USER@
Group=@USER@
WorkingDirectory=/opt/mogotor
Environment=MOGOTOR_ADDR=:8188
Environment=MOGOTOR_DATA_DIR=/var/lib/mogotor
ExecStart=/opt/mogotor/mogotor
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
